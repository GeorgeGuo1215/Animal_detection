# === LivestockMind Agent Environment Variables ===

# LLM API (DeepSeek / OpenAI compatible)
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=deepseek-chat
REASONER_MODEL=deepseek-reasoner

# Web search (optional, for real-time info)
TAVILY_API_KEY=tvly-your-key-here

# Server
LIVESTOCK_AGENT_HOST=0.0.0.0
LIVESTOCK_AGENT_PORT=8000

# Shared RAG with PetMind (agentAndRag on port 8002)
RAG_INDEX_DIR=../agentAndRag/RAG/data/rag_index_e5
RAG_RAW_DIR=../agentAndRag/RAG/data/raw

# RAG relevance — rerank (cross-encoder) and dense (cosine) use different scales
RAG_RERANK_RELEVANCE_THRESHOLD=0.35
RAG_DENSE_RELEVANCE_THRESHOLD=0.12
RAG_WEB_FALLBACK_MIN_HITS=1
RAG_MIN_STRONG_HITS=1
RAG_MIN_DISTINCT_SOURCES=1
AGENT_WARMUP_RAG=1
AGENT_WARMUP_RERANKER=1
AGENT_WARMUP_RERANK_MODEL=BAAI/bge-reranker-large
AGENT_WARMUP_BM25=1

# CORS
AGENT_ENABLE_CORS=1

# Auth (set to 1 to disable API key check)
AGENT_DISABLE_AUTH=0

# MCP tools
AGENT_ENABLE_MCP=1
