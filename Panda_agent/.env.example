# === Panda Mind Agent Environment Variables ===

# LLM API (DeepSeek / OpenAI compatible)
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=deepseek-chat

# Web search (optional, for real-time info)
TAVILY_API_KEY=tvly-your-key-here

# Server
PANDA_AGENT_HOST=0.0.0.0
PANDA_AGENT_PORT=8001

# RAG warmup
AGENT_WARMUP_DEVICE=cuda
AGENT_WARMUP_RAG=1
AGENT_WARMUP_EMBEDDING_MODEL=intfloat/multilingual-e5-small
AGENT_WARMUP_RERANKER=1
AGENT_WARMUP_RERANK_MODEL=BAAI/bge-reranker-large
AGENT_WARMUP_BM25=1

# CORS
AGENT_ENABLE_CORS=1

# Auth (set to 1 to disable API key check)
AGENT_DISABLE_AUTH=0

# MCP tools
AGENT_ENABLE_MCP=1
