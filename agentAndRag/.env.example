# === PetHealthAI Agent 环境变量 ===
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ── LLM API（必需，用于 Agent 对话）──
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# ── Tavily 搜索（可选，用于 MCP 网络搜索工具）──
# TAVILY_API_KEY=your-tavily-key-here

# ── PetMind MySQL（sql.search，只读查询 daily_reports；默认本机 petmind 库）──
# RadarVital 模拟报告默认写入同一个库，Agent 仅通过 sql.search 读取。
PETMIND_MYSQL_HOST=127.0.0.1
PETMIND_MYSQL_PORT=3306
PETMIND_MYSQL_USER=root
PETMIND_MYSQL_PASSWORD=
PETMIND_MYSQL_DATABASE=petmind
# PETMIND_SQL_MAX_LIMIT=200
# AGENT_SQL_DEBUG=0
# sql.search 需在请求中提供 animal_id（JSON 字段或请求头 X-Animal-Id），否则工具不会对 Agent 暴露

# ── Hugging Face / 本地模型（RAG 预热）──
# 无法访问 huggingface.co 时设为 1；若本机已有 HF Hub 缓存目录（如
# %USERPROFILE%\.cache\huggingface\hub\models--intfloat--multilingual-e5-small），
# 启动时会自动解析 snapshots 子目录，一般无需再配 AGENT_EMBEDDING_MODEL_PATH。
# AGENT_HF_OFFLINE=1
# AGENT_EMBEDDING_MODEL_PATH=C:\path\to\multilingual-e5-small
# AGENT_RERANKER_MODEL_PATH=C:\path\to\bge-reranker-large
# 亦可把模型目录放到 agentAndRag/models/multilingual-e5-small（与上方二选一）
# HF_HOME=...   # 自定义 Hugging Face 缓存根（默认 %USERPROFILE%\.cache\huggingface）

# ── n8n 入站（integration 包，合并于 POST /integration/ingest）──
# N8N_WEBHOOK_URL=http://127.0.0.1:5678/webhook/a3ab4cd2-f1f7-4a49-8c66-0669554731ec
# N8N_TIMEOUT_SEC=60

# ── Agent 服务配置 ──
AGENT_ENABLE_CORS=1
AGENT_WARMUP_DEVICE=cuda
AGENT_WARMUP_RAG=1
# AGENT_DISABLE_AUTH=0
# AGENT_RATE_LIMIT=30

# ── 服务地址 ──
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
